# Supabase - obtén estos valores en supabase.com -> tu proyecto -> Settings -> API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Google Maps - obtén la clave en console.cloud.google.com
# Requerida para el mapa nativo en Android/iOS
# En la versión web el mapa muestra una lista alternativa sin esta clave
EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# EAS - se obtiene automáticamente al ejecutar: eas build:configure
EAS_PROJECT_ID=

# Entorno
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=1.0.0